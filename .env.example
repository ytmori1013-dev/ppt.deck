# --- LLM provider ---------------------------------------------------------
# Default provider is Anthropic Claude. Token usage is billed to this key.
ANTHROPIC_API_KEY=sk-ant-...

# Model id used by the agent pipeline (override if needed).
CONSULT_DECK_MODEL=claude-sonnet-4-6

# --- Optional: free local LLM via Ollama ----------------------------------
# Set LLM_PROVIDER=ollama to run fully free against a local model.
# Requires `ollama serve` running locally with the model pulled.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/api
# OLLAMA_MODEL=llama3.1
